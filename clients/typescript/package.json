{
  "name": "@contexta/client",
  "version": "0.1.0",
  "description": "Contexta SDK — persistent memory for AI agents",
  "license": "MIT",
  "author": "Contexta Inc. <dev@contexta.dev>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/*": {
      "import": {
        "types": "./dist/adapters/*.d.ts",
        "default": "./dist/adapters/*.js"
      },
      "require": {
        "types": "./dist/adapters/*.d.ts",
        "default": "./dist/adapters/*.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "contexta",
    "memory",
    "ai",
    "agents",
    "sdk"
  ]
}
