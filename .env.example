CONTEXTA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contexta
CONTEXTA_REDIS_URL=redis://localhost:6379/0
CONTEXTA_CELERY_BROKER_URL=redis://localhost:6379/1
CONTEXTA_CELERY_RESULT_BACKEND=redis://localhost:6379/2
CONTEXTA_CELERY_TASK_ALWAYS_EAGER=false
CONTEXTA_LLM_PROVIDER=openai
CONTEXTA_LLM_MODEL=gpt-4o-mini
CONTEXTA_LLM_API_KEY=
CONTEXTA_EMBEDDING_PROVIDER=openai
CONTEXTA_EMBEDDING_MODEL=text-embedding-3-small
CONTEXTA_EMBEDDING_API_KEY=
